# Arquivo de Secrets - RENOMEAR PARA secrets.toml ANTES DE USAR
# NÃO COMMIT este arquivo com valores reais!
# NUNCA compartilhe seus tokens!

# GitHub API Token
# Obter em: https://github.com/settings/tokens
# Permissões necessárias:
#   - repo (acesso completo ao repositório)
#   - read:org
GITHUB_TOKEN = "ghp_seu_token_github_aqui"

# Senha de Admin para upload/exclusão
# Mude para uma senha segura e única
ADMIN_PASSWORD = "sua_senha_admin_aqui"

# (Opcional) Owner do repositório GitHub
# Se não configurado, usa padrão "biancade"
# GITHUB_OWNER = "seu_usuario_github"

# (Opcional) Nome do repositório
# Se não configurado, usa padrão "dashboard-saneamento"
# GITHUB_REPO = "seu_repo_nome"
